# Makefile for Linux OS Adapter Layer Test
# Usage: make -f Makefile.linux_test

# Compiler and flags
CC = gcc
CFLAGS = -Wall -Wextra -g -I./include -I./3rd/inc -D_GNU_SOURCE
LDFLAGS = -lpthread -lrt

# Source files
OS_SRC = src/gostc_os_linux.c
TEST_SRC = tests/unit/test_os_linux.c
ALL_SRC = $(OS_SRC) $(TEST_SRC)

# Object files
OS_OBJ = $(OS_SRC:.c=.o)
TEST_OBJ = $(TEST_SRC:.c=.o)
ALL_OBJ = $(OS_OBJ) $(TEST_OBJ)

# Target executable
TARGET = test_os_linux

# Default target
all: $(TARGET)

# Build the test executable
$(TARGET): $(ALL_OBJ)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

# Compile source files
%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Run the test
run: $(TARGET)
	./$(TARGET)

# Clean build files
clean:
	rm -f $(ALL_OBJ) $(TARGET)

# Clean and rebuild
rebuild: clean all

# Help
help:
	@echo "Available targets:"
	@echo "  all       - Build the test executable (default)"
	@echo "  run       - Build and run the test"
	@echo "  clean     - Remove build files"
	@echo "  rebuild   - Clean and rebuild"
	@echo "  help      - Show this help message"

.PHONY: all run clean rebuild help